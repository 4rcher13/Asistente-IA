# ═══════════════════════════════════════════════════════════════════════════════
# Archivo de ejemplo de configuración (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
# NUNCA COMMITEAR SECRETOS REALES EN GIT
# Copia este archivo a .env y completa con tus valores reales
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APIs de IA ───────────────────────────────────────────────────────────────
# Obtén tu clave en: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Genera un token en: https://github.com/settings/tokens
# Requiere permisos: repo, read:user, user:email
GITHUB_TOKEN=your_github_token_here

# ─── NVIDIA API ───────────────────────────────────────────────────────────────
# Para DeepSeek Cloud o NVIDIA endpoints
NVIDIA_API_KEY=your_nvidia_api_key_here

# ─── Obsidian Vault ───────────────────────────────────────────────────────────
# Ruta absoluta a tu bóveda de Obsidian (opcional)
OBSIDIAN_VAULT_PATH=C:/Users/YourUser/Documents/YourVault

# ─── Usuario ───────────────────────────────────────────────────────────────────
# Nombre para personalizar respuestas
USER_NAME=Tu_Nombre

# ─── Ollama (Local LLM) ───────────────────────────────────────────────────────
# Modelo local para fallback (si Gemini no está disponible)
MODELO_OLLAMA=qwen2.5:1.5b
